# Evolution API v2 — EasyPanel environment template
SERVER_URL=https://evolution.your-domain.com
AUTHENTICATION_API_KEY=generate-a-long-random-api-key
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@postgres:5432/evolution
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379
LOG_LEVEL=ERROR,WARN,DEBUG,INFO
QRCODE_LIMIT=30
WEBHOOK_GLOBAL_ENABLED=false
