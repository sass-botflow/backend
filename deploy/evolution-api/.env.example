# Evolution API — production environment template
# Copy to .env and replace every CHANGE_ME value before deploying.

# ─── Server ───────────────────────────────────────────────────────
# Public URL assigned in EasyPanel (Domains tab). Required by Evolution API.
# Use HTTPS once the domain is bound. BotFlow backend calls the API internally
# via http://evolution-api:8080 — this URL is for Evolution's own metadata.
SERVER_NAME=botflow-evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://evolution.api.botflow.ink

# Global API key — sent as the `apikey` header on every request.
# Must match EVOLUTION_API_KEY on the BotFlow backend.
AUTHENTICATION_API_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_KEY
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# ─── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:CHANGE_ME_DB_PASSWORD@evolution-postgres:5432/evolution?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=botflow_evolution

POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Persist instance metadata in PostgreSQL (recommended for production)
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false

# ─── Redis cache ──────────────────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=botflow_evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ─── Disabled for phase 1 (no QR / webhooks / websocket yet) ─────
WEBSOCKET_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
RABBITMQ_ENABLED=false
SQS_ENABLED=false
PUSHER_ENABLED=false
KAFKA_ENABLED=false

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=false
LOG_BAILEYS=error
LANGUAGE=en

# ─── Instances ────────────────────────────────────────────────────
# Keep instances in memory/DB after disconnect (recommended for SaaS)
DEL_INSTANCE=false

# ─── Session display (shown on phone during future QR connect) ───
CONFIG_SESSION_PHONE_CLIENT=BotFlow
CONFIG_SESSION_PHONE_NAME=Chrome
