# EasyPanel → evolution-api Compose → Environment
# ONLY these 3 variables belong here. Do NOT add WEBHOOK_GLOBAL_ENABLED,
# WEBSOCKET_ENABLED, or other keys — they are hardcoded in docker-compose.yml.
# Adding them in EasyPanel causes: invalid interpolation format ... WEBHOOK_GLOBAL_ENABLED

SERVER_URL=https://evolution.api.botflow.ink
AUTHENTICATION_API_KEY=PUT_YOUR_SECRET_KEY_HERE
DATABASE_CONNECTION_URI=postgresql://botflow:YOUR_PASSWORD@sass-botflow_postgres:5432/evolution?schema=evolution_api
