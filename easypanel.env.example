# EasyPanel → backend → Environment
# Copy-paste these vars, then fill secrets marked CHANGE_ME

NODE_ENV=production
PORT=8000

# PostgreSQL (use EasyPanel internal hostname, NOT localhost)
DATABASE_URL=postgresql://botflow:botflow@sass-botflow_postgres:5432/postgres?sslmode=disable

# Auth — required (min 32 chars)
JWT_SECRET=CHANGE_ME_min_32_random_characters_here

# Evolution API — required for WhatsApp QR
EVOLUTION_API_URL=http://sass-botflow_evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME_same_as_evolution_AUTHENTICATION_API_KEY
EVOLUTION_WEBHOOK_URL=https://api.botflow.ink/webhooks/evolution
BACKEND_URL=https://api.botflow.ink

# App URLs
FRONTEND_URL=https://www.botflow.ink
CORS_ORIGIN=https://botflow.ink,https://www.botflow.ink

# n8n automation
N8N_WEBHOOK_URL=https://ecomgcc21.app.n8n.cloud/webhook/0edc08c4-6908-43ce-8f9f-dbc5ace31958

# Instagram OAuth (Meta Graph API)
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME
META_REDIRECT_URI=https://api.botflow.ink/api/auth/instagram/callback
META_GRAPH_API_VERSION=v21.0
INSTAGRAM_OAUTH_FLOW=instagram
