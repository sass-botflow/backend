NODE_ENV=development
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql://botflow:botflow@localhost:5432/botflow

# Redis
REDIS_URL=redis://localhost:6379

# Auth (JWT — used by frontend / Clerk bridge)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.botflow.ink/api/auth/google/callback

# CORS (comma-separated)
CORS_ORIGIN=https://botflow.ink,https://www.botflow.ink,http://localhost:3000

# Frontend
FRONTEND_URL=https://www.botflow.ink

# Evolution API (WhatsApp Web)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_WEBHOOK_URL=https://api.botflow.ink/webhooks/evolution
BACKEND_URL=https://api.botflow.ink

