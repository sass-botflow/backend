NODE_ENV=development
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql://botflow:botflow@localhost:5432/botflow

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.botflow.ink/api/auth/google/callback

# CORS (comma-separated)
CORS_ORIGIN=https://botflow.ink,https://www.botflow.ink,http://localhost:3000

# Frontend (OAuth redirect after WhatsApp connect)
FRONTEND_URL=https://botflow.ink

# Meta Embedded Signup (WhatsApp)
META_APP_ID=
META_APP_SECRET=
# Must match Meta App → Facebook Login for Business → Valid OAuth Redirect URIs
META_WHATSAPP_REDIRECT_URI=https://api.botflow.ink/api/channels/whatsapp/callback
# Legacy alias (optional); do not set to /meta/callback
META_REDIRECT_URI=https://api.botflow.ink/api/channels/whatsapp/callback
META_VERIFY_TOKEN=change-me-to-a-random-verify-token

# Encrypt WhatsApp access tokens at rest (32 bytes: 64-char hex or base64)
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# n8n automation
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/botflow-whatsapp

# Legacy WhatsApp integration OAuth (integrations module)
META_OAUTH_REDIRECT_URI=https://api.botflow.ink/api/integrations/whatsapp/oauth/callback

# Evolution API (WhatsApp via Baileys)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_AGENCY=
