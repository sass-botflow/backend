{
  "name": "sass-botflow-backend",
  "version": "0.1.0",
  "description": "Backend API for the Sass Botflow SaaS platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
